# AWS Configuration
VITE_API_KEY=your_api_gateway_key
VITE_AWS_REGION=us-east-1

# Amazon Cognito (add when User Pool is created)
# VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Amazon Translate (via API Gateway)
# VITE_TRANSLATE_ENDPOINT=https://your-api-id.execute-api.us-east-1.amazonaws.com

# Amazon SNS (via API Gateway — for SMS notifications)
# VITE_SNS_ENDPOINT=https://your-api-id.execute-api.us-east-1.amazonaws.com
